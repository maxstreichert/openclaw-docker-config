{
  "gateway": {
    "mode": "local",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "dmPolicy": "allowlist",
      "allowFrom": ["40797203"],
      "groupPolicy": "allowlist",
      "groupAllowFrom": [
        "40797203"
      ],
      "streamMode": "partial"
    }
  },

  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "google/gemini-3-flash-preview"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 4
      }
    }
  },

  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  },

  "messages": {
    "ackReactionScope": "group-mentions"
  },

  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      }
    }
  },

  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "redactSensitive": "tools"
  }
}